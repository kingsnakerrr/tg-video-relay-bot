(common) {
    encode zstd gzip
    request_body {
        max_size 30MB
    }
    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains"
        X-Frame-Options "DENY"
        Referrer-Policy "no-referrer"
        -Server
    }
}

https://{$DOMAIN}:7078 {
    import common

    @backend path /admin* /api/admin-login /api/setup /api/settings* /api/users*
    respond @backend "Not found" 404

    @delete {
        method DELETE
        path /api/images/*
    }
    respond @delete "Forbidden" 403

    reverse_proxy drivepic:3000
}

https://{$DOMAIN}:7077 {
    import common
    reverse_proxy drivepic:3000
}
